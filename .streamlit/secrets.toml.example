# Copy this to `.streamlit/secrets.toml` for local dev, and paste the same content into
# Streamlit Cloud → App → Settings → Secrets. DO NOT commit the real secrets.toml.

# Shared password to open the app (Streamlit Cloud). Remove/leave unset to disable the gate.
app_password = "change-me"

# GCP service-account key (BigQuery read access to paystand.*). Paste the JSON key fields here.
[gcp_service_account]
type = "service_account"
project_id = "paystand"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-sa@paystand.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
